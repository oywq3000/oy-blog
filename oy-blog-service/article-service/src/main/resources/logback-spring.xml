<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--============================================
        Property defaults
        LOG_PATH can be overridden via application.yml
        or JVM argument -DLOG_PATH=/var/log/oy-blog
    ============================================-->
    <property name="LOG_PATH" value="${LOG_PATH:-logs}" />
    <property name="MODULE_NAME" value="article-service" />
    <property name="MAX_HISTORY" value="15" />
    <property name="MAX_FILE_SIZE" value="100MB" />

    <!--============================================
        Console Appender
        Used in all environments; supports ANSI colors
    ============================================-->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) [%X{recordId:-no-record}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!--============================================
        Rolling File Appender - Application Log
    ============================================-->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${MODULE_NAME}/${MODULE_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${MODULE_NAME}/${MODULE_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{recordId:-no-record}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!--============================================
        Rolling File Appender - HTTP Access Log
        Dedicated log for request/response traffic
    ============================================-->
    <appender name="ACCESS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${MODULE_NAME}/${MODULE_NAME}-access.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${MODULE_NAME}/${MODULE_NAME}-access.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>200MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{recordId:-no-record}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!--============================================
        Route access logs to the ACCESS appender
    ============================================-->
    <logger name="com.oyproj.common.logging.access" level="INFO" additivity="false">
        <appender-ref ref="ACCESS" />
        <appender-ref ref="CONSOLE" />
    </logger>

    <!--============================================
        Per-package log levels
    ============================================-->
    <logger name="com.oyproj" level="DEBUG" />
    <logger name="org.springframework" level="WARN" />
    <logger name="org.springframework.security" level="WARN" />
    <logger name="com.baomidou" level="WARN" />
    <logger name="org.mybatis" level="WARN" />
    <logger name="org.apache" level="WARN" />
    <logger name="io.lettuce" level="WARN" />

    <!--============================================
        Root Logger
    ============================================-->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>
</configuration>
